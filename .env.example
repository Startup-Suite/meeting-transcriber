# ── LiveKit server ──────────────────────────────────────────────────────────
# The agent connects to this server as a worker and waits for job
# assignments. Same creds your Suite `core` app uses for meetings.
LIVEKIT_URL=wss://your-livekit-server.example.com
LIVEKIT_API_KEY=your_api_key
LIVEKIT_API_SECRET=your_api_secret

# ── STT backend (OpenAI-compatible) ─────────────────────────────────────────
# Any OpenAI-compatible `/v1/audio/transcriptions` endpoint works:
#   - OpenAI hosted Whisper      → https://api.openai.com/v1
#   - speaches (self-hosted GPU) → http://your-speaches-host:8000/v1
#   - faster-whisper-server      → http://your-fwsvr-host:8000/v1
#   - Deepgram (OpenAI-compat)   → https://api.deepgram.com/v1
STT_BASE_URL=https://api.openai.com/v1
STT_API_KEY=sk-your-api-key-or-'none'-for-self-hosted
STT_MODEL=whisper-1
# Other STT_MODEL examples:
#   whisper-1                                         (OpenAI hosted)
#   Systran/faster-distil-whisper-small.en            (speaches — fast English)
#   Systran/faster-whisper-large-v3                   (speaches — best multilingual)
#   Systran/faster-distil-whisper-medium.en           (speaches — middle ground)

# ── Room selection ──────────────────────────────────────────────────────────
# Glob pattern for room names this worker will accept jobs for. Rooms
# not matching are rejected so you can run multiple LiveKit agents on
# the same server (e.g. a phone-call agent alongside this transcriber).
#
# For Startup Suite core: ROOM_PATTERN=space-*
# For "transcribe everything": ROOM_PATTERN=*
ROOM_PATTERN=space-*

# ── Behavior ────────────────────────────────────────────────────────────────
IDLE_TIMEOUT_S=300
LOG_LEVEL=INFO
